{
  "name": "architecture-linter",
  "version": "0.1.0",
  "description": "A CLI tool that enforces architecture rules in TypeScript projects",
  "keywords": ["architecture", "linter", "typescript", "dependency", "layers"],
  "license": "MIT",
  "bin": {
    "architecture-linter": "./dist/cli.js"
  },
  "scripts": {
