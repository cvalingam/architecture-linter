{
  "name": "architecture-linter-vscode",
  "displayName": "Architecture Linter",
  "description": "Enforce architectural layer rules in TypeScript projects — inline diagnostics, fix hints, and real-time feedback on every save.",
  "version": "0.1.6",
  "publisher": "cvalingam",
  "repository": {
    "type": "git",
    "url": "https://github.com/cvalingam/architecture-linter"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Linters"],
  "keywords": [
    "architecture", "linter", "typescript", "clean-architecture",
    "nestjs", "hexagonal", "layer", "import"
  ],
  "activationEvents": [
    "workspaceContains:.context.yml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "architecture-linter.scan",
        "title": "Scan Architecture",
        "category": "Architecture Linter"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.4.0"
  }
}
